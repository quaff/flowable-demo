<?xml version="1.0" encoding="UTF-8"?>
<definitions
        xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
        xmlns:flowable="http://flowable.org/bpmn"
        targetNamespace="Examples">

    <process id="simpleProcess" name="The Simple Process" flowable:initiator="startUserId">
        <startEvent id="start" />
        <sequenceFlow id="flow1" sourceRef="start" targetRef="userTask" />
        <userTask id="userTask" name="User Task" flowable:assignee="${startUserId}" />
        <sequenceFlow id="flow2" sourceRef="userTask" targetRef="end" />
        <endEvent id="end" />
    </process>

</definitions>